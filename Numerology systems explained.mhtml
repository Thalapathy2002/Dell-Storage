@keyframes pulse-dot {=20
  0% { opacity: 0.1; scale: 0.7; }
  50% { transform: scale(var(--pulse-scale,1.3)); opacity: 1; }
  100% { opacity: 0; transform: scale(0.7); }
}

@keyframes float-sidebar-in {=20
  0% { opacity: 0; translate: -60%; }
  70% { opacity: 1; }
  100% { translate: 0px; }
}

@keyframes float-sidebar-out {=20
  0% { translate: 0px; }
  30% { opacity: 1; }
  100% { opacity: 0; translate: -60%; }
}

@media (prefers-reduced-motion: no-preference) {
  .pulsing-dot { opacity: 0; animation-duration: ; animation-timing-functio=
